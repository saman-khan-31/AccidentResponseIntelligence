					</EditorProperties>
				</CalculatedItem>
				<CalculatedItem dataType="double" name="bi541" label="Average Response Time" usage="quantitative" format="COMMA12.2" aggregation="average">
					<Expression>2.5</Expression>
					<EditorProperties>
						<Property key="USER_EDIT_REPRESENTATION">2.5</Property>
					</EditorProperties>
				</CalculatedItem>
				<CalculatedItem dataType="double" name="bi543" label="High Risk Zones Count" usage="quantitative" format="COMMA12." aggregation="average">
					<Expression>3</Expression>
