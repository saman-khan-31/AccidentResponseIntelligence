					<Expression>datepart(${bi538,binned})</Expression>
					<EditorProperties>
						<Property key="USER_EDIT_REPRESENTATION">DatePart(&apos;createdAt DateTime&apos;n)</Property>
					</EditorProperties>
				</CalculatedItem>
				<CalculatedItem dataType="double" name="bi614" label="Accident Day" usage="quantitative" format="COMMA12." aggregation="sum">
					<Expression>dow(${bi613,binned})</Expression>
