					<Expression>cond(eq(${bi517,raw},2),&apos;Units Dispatched&apos;,&apos;Units on Scene&apos;)</Expression>
					<EditorProperties>
						<Property key="USER_EDIT_REPRESENTATION">IF &apos;Response Wave&apos;n = 2 RETURN &apos;Units Dispatched&apos; ELSE &apos;Units on Scene&apos;</Property>
